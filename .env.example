# Copy these variable names into Railway → Variables tab
# Railway provides DB_* variables automatically if you add a MySQL plugin

SECRET_KEY=generate-a-long-random-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.up.railway.app

# Database — Railway MySQL plugin sets these automatically
DB_NAME=railway
DB_USER=root
DB_PASSWORD=
DB_HOST=
DB_PORT=3306

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=oceanwavesseafoods@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# Security (set to True in production)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
